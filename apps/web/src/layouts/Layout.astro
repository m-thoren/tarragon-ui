---
import NavigationAccordion from '@/components/NavigationAccordion.astro'
import type { Page } from '@/scripts/constants'
import RootLayout from './RootLayout.astro'

type Props = {
	currentPage: Page | undefined
}

const { currentPage } = Astro.props
---

<RootLayout currentPage={currentPage}>
	<div class='flex-1 container'>
		<div class='grid-desktop gap-xl padding-block-3xl'>
			<aside class='show-above-desktop cell-one-fourth'>
				<NavigationAccordion currentPage={currentPage} />
			</aside>
			<main id='main' tabindex='-1' class='cell-three-fourths'>
				<slot />
			</main>
		</div>
	</div>
</RootLayout>
