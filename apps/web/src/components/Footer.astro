---
import { buildUrl, siteTitle } from '@/scripts/constants'
import BrandIcon from '../assets/brand-icon.svg'
---

<footer class='container'>
	<div class='footer-content'>
		<div class='footer-brand stack max-w-7xl'>
			<div class='cluster'>
				<BrandIcon aria-hidden='true' />
				{siteTitle}
			</div>
			<p>Lightweight CSS and WebComponents for performant and accessible applications</p>
		</div>
		<section class='stack gap-xs'>
			<h2 class='h4'>Code</h2>
			<ul class='list-none padding-0'>
				<li>
					<a href='https://github.com/m-thoren/tarragon-ui' class='link-subtle'>Github</a>
				</li>
				<li>
					<a href='https://www.npmjs.com/package/@tarragon-ui/styles' class='link-subtle'>
						CSS
					</a>
				</li>
				<li>
					<a href='https://www.npmjs.com/package/@tarragon-ui/js' class='link-subtle'>
						JavaScript
					</a>
				</li>
			</ul>
		</section>
		<section class='stack gap-xs'>
			<h2 class='h4'>Docs</h2>
			<ul class='list-none padding-0'>
				<li><a href={buildUrl('/search-filter')} class='link-subtle'>Search</a></li>
				<li>
					<a href={buildUrl('/installation')} class='link-subtle'>Installation</a>
				</li>
				<li>
					<a href={buildUrl('/changelog')} class='link-subtle'>Changelog</a>
				</li>
			</ul>
		</section>
	</div>
</footer>
