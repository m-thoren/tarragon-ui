---
import ComponentLayout from '@/layouts/ComponentLayout.astro'
import { Image } from 'astro:assets'
---

<ComponentLayout name='Avatar'>
	<div class='stack cluster-tablet'>
		<Image
			class='avatar'
			src='https://images.unsplash.com/photo-1534528741775-53994a69daeb?q=80&w=200&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D'
			alt='A woman looking at the camera against a purple background'
			width={200}
			height={200}
		/>
		<Image
			class='avatar'
			src='https://images.unsplash.com/photo-1534528741775-53994a69daeb?q=80&w=100&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D'
			alt='A woman looking at the camera against a purple background'
			width={100}
			height={100}
		/>
		<Image
			class='avatar'
			src='https://images.unsplash.com/photo-1534528741775-53994a69daeb?q=80&w=50&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D'
			alt='A woman looking at the camera against a purple background'
			width={50}
			height={50}
		/>
	</div>
</ComponentLayout>
