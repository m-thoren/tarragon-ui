---
import ComponentLayout from '@/layouts/ComponentLayout.astro'
import { buildUrl } from '@/scripts/constants'
---

<ComponentLayout name='Padding'>
	<p>
		Combine the following padding classes with the <a href={buildUrl('/size')}>size values</a>
	</p>
	<ul>
		<li><code>.padding-{`{size}`}</code></li>
		<li><code>.padding-block-{`{size}`}</code></li>
		<li><code>.padding-block-start-{`{size}`}</code></li>
		<li><code>.padding-block-end-{`{size}`}</code></li>
		<li><code>.padding-inline-{`{size}`}</code></li>
		<li><code>.padding-inline-start-{`{size}`}</code></li>
		<li><code>.padding-inline-end-{`{size}`}</code></li>
	</ul>
</ComponentLayout>
