---
import ComponentLayout from '@/layouts/ComponentLayout.astro'
import { Image } from 'astro:assets'
---

<ComponentLayout name='Figure'>
	<div class='cluster'>
		<figure>
			<Image
				class='image'
				src='https://images.unsplash.com/photo-1773062189964-75a471b19934?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D'
				width={300}
				height={300}
				alt='A blue vinyl record player on a wooden side table'
			/>
			<figcaption>
				A blue vinyl record player
				<span class='photo-by'>Photo: unsplash.com</span>
			</figcaption>
		</figure>
		<figure>
			<Image
				class='image aspect-ratio-21x9'
				src='https://images.unsplash.com/photo-1764054655220-99548fc12fe3?q=80&w=987&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D'
				width={300}
				height={169}
				alt='Rocks stacked on top of each other on a beach with a body of water in the background'
			/>
			<figcaption>
				Stacked rocks
				<span class='photo-by'>Photo: unsplash.com</span>
			</figcaption>
		</figure>
		<figure>
			<Image
				class='image aspect-ratio-4x3'
				src='https://plus.unsplash.com/premium_photo-1748106667800-16a64574c05f?q=80&w=2071&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D'
				width={300}
				height={225}
				alt='A white room containing a stool, a chari and a plant in a pot'
			/>
			<figcaption>
				A white room
				<span class='photo-by'>Photo: unsplash.com</span>
			</figcaption>
		</figure>
	</div>
</ComponentLayout>
