---
import CodeExample from '@/components/CodeExample.astro'
import ComponentLayout from '@/layouts/ComponentLayout.astro'
---

<ComponentLayout name='Input'>
	<CodeExample>
		<div class='form-group'>
			<label for='input-text'>Text</label>
			<input type='text' id='input-text' autocomplete='username' />
		</div>
	</CodeExample>
	<CodeExample>
		<div class='form-group'>
			<label for='input-password'>Password</label>
			<input type='password' id='input-password' autocomplete='current-password' />
		</div>
	</CodeExample>
	<CodeExample>
		<div class='form-group'>
			<label for='input-email'>Email</label>
			<input type='email' id='input-email' inputmode='email' autocomplete='email' />
		</div>
	</CodeExample>
	<CodeExample>
		<div class='form-group'>
			<label for='input-number'>Number</label>
			<input type='number' id='input-number' inputmode='numeric' />
		</div>
	</CodeExample>
	<CodeExample>
		<div class='form-group'>
			<label for='input-date'>Date</label>
			<input type='date' id='input-date' autocomplete='bday' />
		</div>
	</CodeExample>
	<CodeExample>
		<div class='form-group'>
			<label for='input-file'>File</label>
			<input type='file' id='input-file' />
		</div>
		<div class='form-group'>
			<label for='input-file-outline'>File (Outline)</label>
			<input type='file' id='input-file-outline' class='outline' />
		</div>
		<div class='form-group'>
			<label for='input-file-warning'>File (Warning)</label>
			<input type='file' id='input-file-warning' class='warning' />
		</div>
	</CodeExample>
</ComponentLayout>
