---
import CodeExample from '@/components/CodeExample.astro'
import ComponentLayout from '@/layouts/ComponentLayout.astro'
---

<ComponentLayout name='Join'>
	<CodeExample>
		<div class='join'>
			<button class='outline'>Item 1</button>
			<button class='outline'>Item 2</button>
			<button class='outline'>Item 3</button>
		</div>
	</CodeExample>

	<h2>Use with nested elements</h2>
	<CodeExample>
		<div class='join'>
			<button class='outline'>Item 1</button>
			<div>
				<button class='outline join-item'>Item 2</button>
			</div>
			<button class='outline'>Item 3</button>
		</div>
	</CodeExample>
</ComponentLayout>
